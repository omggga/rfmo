# RFMO client credentials.
RFMO_API_USERNAME=
RFMO_API_PASSWORD=

# Local address of the mTLS gateway.
# With https://github.com/omggga/mtls defaults this is usually:
#   http://localhost:3010/rfmo
RFMO_MTLS_PROTOCOL=http
RFMO_MTLS_HOST=localhost
RFMO_MTLS_PORT=3010
RFMO_MTLS_PATH=/rfmo

# Optional runtime behavior.
RFMO_CONTOUR=prod
RFMO_API_TIMEOUT_MS=60000
RFMO_API_RETRY_ATTEMPTS=2
RFMO_CAPTURE_ENVELOPES=0
RFMO_ENVELOPES_DIR=./rfmo-envelopes
